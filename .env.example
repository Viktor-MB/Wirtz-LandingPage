# Copie este arquivo para ".env" e preencha os valores.
#   No PowerShell:  Copy-Item .env.example .env
#   No bash:        cp .env.example .env
#
# IMPORTANTE: o arquivo .env está no .gitignore e NUNCA deve ser commitado.
# Se as duas variáveis ficarem vazias, o site usa automaticamente os dados
# mockados (25+ anos, 29 profissionais, 21 especialidades) e nada quebra.

# URL base da API (sem a barra no final). Ex.: https://api.suaclinica.com
VITE_API_BASE=

# Chave/token da API.
VITE_API_KEY=
